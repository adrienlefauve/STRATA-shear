"""
local_config.py - per-machine path overrides.

HOW TO USE
----------
1. Copy this file to `local_config.py` in the same directory:

       cp local_config.py.example local_config.py

2. Edit `local_config.py` to match your filesystem.

3. The scripts in this repo will pick it up automatically. If you don't
   create `local_config.py`, the scripts fall back to safe placeholder
   defaults - you'll then need to pass paths via the CLI flags
   (e.g. `--snapshots`, `--project-root`, `--code-root`).

`local_config.py` is git-ignored, so it never gets committed.

PATHS
-----
Set the variables your workflow needs. Anything you leave commented out
will fall back to a generic default (see each script).
"""

from pathlib import Path

